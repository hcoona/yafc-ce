{
  "servers": {
    "io.github.upstash/context7": {
      "type": "stdio",
      "command": "mise",
      "args": ["exec", "node@24", "--", "pnpm", "dlx", "@upstash/context7-mcp@1.0.30"],
      "env": {
        "CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
      }
    },
    "microsoft-learn": {
      "type": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  },
  "inputs": [
    {
      "id": "CONTEXT7_API_KEY",
      "type": "promptString",
      "description": "API key for authentication",
      "password": true
    }
  ]
}
